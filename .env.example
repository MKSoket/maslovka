BOT_TOKEN=123456:replace_me

# Run /chatid in the coordinator group and paste the negative chat id here.
COORDINATOR_CHAT_ID=

DATABASE_PATH=bot.sqlite3
FAQ_SEED_PATH=data/faq_seed.json
FAQ_MATCH_THRESHOLD=0.57
LOCAL_DIRECT_MATCH_THRESHOLD=0.86
HISTORY_LIMIT=0
AUTO_CLOSE_AFTER_COORDINATOR_REPLY=true

# Optional: improves FAQ recognition with Gemini before creating a coordinator ticket.
GEMINI_API_KEY=
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MIN_CONFIDENCE=0.70
GEMINI_TIMEOUT_SECONDS=8
